# === Telegram ===
# Get from @BotFather on Telegram → /newbot
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID — message @userinfobot to get it
# Comma-separated for multiple admins: 123456789,987654321
ADMIN_CHAT_IDS=

# === Supabase ===
# Same URL as VITE_SUPABASE_URL in the frontend .env
SUPABASE_URL=

# IMPORTANT: Use the service_role key (NOT the anon key)
# Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# === Gemini ===
GEMINI_API_KEY=
